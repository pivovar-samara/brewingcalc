// Firebase configuration — copy this file to Secrets.xcconfig and fill in real values.
// Secrets.xcconfig is gitignored and must never be committed.
//
// On CI: generate Secrets.xcconfig from repository secrets before building, e.g.:
//   echo "FIREBASE_API_KEY=$FIREBASE_API_KEY" >> Configs/Secrets.xcconfig
//   echo "FIREBASE_APP_ID=$FIREBASE_APP_ID" >> Configs/Secrets.xcconfig
//   echo "FIREBASE_GCM_SENDER_ID=$FIREBASE_GCM_SENDER_ID" >> Configs/Secrets.xcconfig
//   echo "FIREBASE_PROJECT_ID=$FIREBASE_PROJECT_ID" >> Configs/Secrets.xcconfig
//   echo "FIREBASE_STORAGE_BUCKET=$FIREBASE_STORAGE_BUCKET" >> Configs/Secrets.xcconfig

FIREBASE_API_KEY = YOUR_API_KEY
FIREBASE_APP_ID = YOUR_APP_ID
FIREBASE_GCM_SENDER_ID = YOUR_GCM_SENDER_ID
FIREBASE_PROJECT_ID = YOUR_PROJECT_ID
FIREBASE_STORAGE_BUCKET = YOUR_STORAGE_BUCKET
